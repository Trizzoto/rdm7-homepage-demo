{% comment %}
  RDM Home — Hero with live WASM-powered RDM-7 dashboard
  Place in: sections/rdm-home-hero.liquid

  The dashboard preview is rendered by an iframe pointing at the
  rdm7-homepage-demo deployment (the actual firmware UI compiled to
  WebAssembly). Replaces the previous hand-built HTML animation.

  Configure the demo URL + mobile gate via the section settings in the
  theme customizer. Everything else (copy, images, CTAs, stats, status
  strip) is editable from the customizer as before.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  #rdm-hero-{{ section.id }} {
    position: relative !important;
    background: radial-gradient(ellipse 90% 70% at 50% 45%, #2a2a2a 0%, #1a1a1a 35%, #0a0a0a 70%, #000 100%) !important;
    color: #fff !important;
    padding: 140px 0 60px !important;
    overflow: hidden !important;
    font-family: 'Inter', system-ui, sans-serif !important;
  }
  #rdm-hero-{{ section.id }} .rh-container {
    max-width: 1440px !important;
    margin: 0 auto !important;
    padding: 0 clamp(20px, 4vw, 56px) !important;
  }
  #rdm-hero-{{ section.id }} .rh-bg { position: absolute !important; inset: 0 !important; pointer-events: none !important; z-index: 0 !important; }
  #rdm-hero-{{ section.id }} .rh-bg-grid {
    position: absolute !important; inset: 0 !important;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px) !important;
    background-size: 64px 64px !important;
    mask-image: radial-gradient(ellipse at center, black 40%, transparent 85%) !important;
    -webkit-mask-image: radial-gradient(ellipse at center, black 40%, transparent 85%) !important;
  }
  #rdm-hero-{{ section.id }} .rh-bg-num {
    position: absolute !important;
    left: 50% !important; top: 50% !important;
    transform: translate(-50%, -50%) !important;
    font-family: 'Space Grotesk', 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(320px, 42vw, 680px) !important;
    line-height: 0.8 !important;
    color: rgba(255,255,255,0.055) !important;
    letter-spacing: -0.04em !important;
    user-select: none !important;
    font-variant-numeric: tabular-nums !important;
    white-space: nowrap !important;
  }
  /* Hero layout grid — bezel slots between title and subcopy on mobile */
  #rdm-hero-{{ section.id }} .rh-inner {
    position: relative !important; z-index: 1 !important;
    display: grid !important;
    grid-template-columns: 1fr 1fr !important;
    column-gap: 60px !important;
    row-gap: 0 !important;
    align-items: start !important;
  }
  #rdm-hero-{{ section.id }} .rh-eyebrow,
  #rdm-hero-{{ section.id }} .rh-title,
  #rdm-hero-{{ section.id }} .rh-sub,
  #rdm-hero-{{ section.id }} .rh-cta      { grid-column: 1 !important; }
  #rdm-hero-{{ section.id }} .rh-bezel    { grid-column: 2 !important; grid-row: 1 / span 4 !important; align-self: center !important; }

  @media (max-width: 1080px) {
    #rdm-hero-{{ section.id }} .rh-inner  { grid-template-columns: 1fr !important; }
    #rdm-hero-{{ section.id }} .rh-eyebrow{ grid-column: 1 !important; grid-row: 1 !important; }
    #rdm-hero-{{ section.id }} .rh-title  { grid-column: 1 !important; grid-row: 2 !important; }
    #rdm-hero-{{ section.id }} .rh-bezel  { grid-column: 1 !important; grid-row: 3 !important; margin: 28px 0 !important; align-self: stretch !important; }
    #rdm-hero-{{ section.id }} .rh-sub    { grid-column: 1 !important; grid-row: 4 !important; }
    #rdm-hero-{{ section.id }} .rh-cta    { grid-column: 1 !important; grid-row: 5 !important; }
  }
  @media (max-width: 720px) {
    #rdm-hero-{{ section.id }} { padding: 88px 0 40px !important; }
    #rdm-hero-{{ section.id }} .rh-eyebrow { margin-bottom: 20px !important; }
    #rdm-hero-{{ section.id }} .rh-title   { font-size: clamp(36px, 10vw, 54px) !important; }
    #rdm-hero-{{ section.id }} .rh-sub     { margin-top: 24px !important; font-size: 14px !important; }
    #rdm-hero-{{ section.id }} .rh-cta     { margin-top: 28px !important; }
    #rdm-hero-{{ section.id }} .rh-stats   { margin-top: 40px !important; }
  }
  #rdm-hero-{{ section.id }} .rh-eyebrow {
    display: inline-flex !important; align-items: center !important; gap: 8px !important;
    color: #CC0000 !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 11px !important; font-weight: 600 !important;
    letter-spacing: 0.18em !important;
    margin-bottom: 40px !important;
    text-transform: uppercase !important;
  }
  #rdm-hero-{{ section.id }} .rh-eyebrow-dot { font-size: 16px !important; line-height: 1 !important; }
  #rdm-hero-{{ section.id }} .rh-title {
    font-family: 'Space Grotesk', 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(48px, 6.4vw, 104px) !important;
    line-height: 0.98 !important;
    letter-spacing: -0.035em !important;
    margin: 0 !important;
  }
  #rdm-hero-{{ section.id }} .rh-title-white { color: #fff !important; display: block !important; }
  #rdm-hero-{{ section.id }} .rh-title-red { color: #CC0000 !important; display: block !important; margin-top: 4px !important; font-size: clamp(28px, 8vw, 90px) !important; }
  #rdm-hero-{{ section.id }} .rh-sub {
    margin-top: 36px !important;
    max-width: 440px !important;
    font-family: 'Space Grotesk', 'Inter', sans-serif !important;
    font-size: 15px !important; line-height: 1.6 !important;
    color: rgba(255,255,255,0.55) !important;
    font-weight: 400 !important;
  }
  #rdm-hero-{{ section.id }} .rh-cta { margin-top: 40px !important; display: flex !important; gap: 12px !important; flex-wrap: wrap !important; }
  #rdm-hero-{{ section.id }} .rh-btn {
    display: inline-flex !important; align-items: center !important; gap: 10px !important;
    padding: 14px 22px !important;
    background: #CC0000 !important; color: #fff !important;
    font-family: 'Space Grotesk', 'Inter', sans-serif !important;
    font-weight: 600 !important; font-size: 14px !important;
    letter-spacing: 0.01em !important;
    border-radius: 2px !important;
    text-decoration: none !important;
    transition: background 200ms ease, transform 200ms ease !important;
  }
  #rdm-hero-{{ section.id }} .rh-btn:hover { background: #FF3333 !important; transform: translateX(2px) !important; }
  #rdm-hero-{{ section.id }} .rh-btn:focus-visible { outline: 2px solid #FF3333 !important; outline-offset: 3px !important; }
  #rdm-hero-{{ section.id }} .rh-btn:active { transform: translateX(1px) scale(0.98) !important; }
  #rdm-hero-{{ section.id }} .rh-btn--ghost {
    background: transparent !important; color: #fff !important;
    border: 1px solid rgba(255,255,255,0.2) !important;
  }
  #rdm-hero-{{ section.id }} .rh-btn--ghost:hover { background: rgba(255,255,255,0.05) !important; border-color: rgba(255,255,255,0.4) !important; transform: none !important; }

  /* Bezel — uses 1000/611 outer aspect so that, after the 14 px padding
   * eats into both axes, the inner .rh-screen ends up at the canvas's
   * native 800×480 (5:3) ratio. That way the WASM dash fills the screen
   * edge-to-edge with no black bars, while still leaving a real-looking
   * automotive housing margin on every side. Visibly wider than tall
   * without being letterbox-cinema. */
  #rdm-hero-{{ section.id }} .rh-bezel {
    justify-self: center !important;
    width: 100% !important; max-width: 1000px !important;
    aspect-ratio: 1000 / 611 !important;
    background: #1a1a1a !important;
    border-radius: 18px !important;
    padding: 14px !important;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6), inset 0 0 0 1px rgba(255,255,255,0.05) !important;
  }
  #rdm-hero-{{ section.id }} .rh-screen {
    width: 100% !important; height: 100% !important;
    background: #000 !important;
    border-radius: 6px !important;
    overflow: hidden !important;
    position: relative !important;
  }
  /* WASM demo iframe — fills the screen, no chrome of its own when
   * loaded with ?bare=1. Transparent background lets the bezel's pure
   * black show through for the off-canvas margins. */
  #rdm-hero-{{ section.id }} .rh-dash-iframe {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    border: 0 !important;
    background: #000 !important;
  }

  /* Center-of-dash RDM logo overlay.
   * Sits on top of the canvas at a fixed proportion of the screen
   * (16.25% wide = 130 px when the canvas renders at its native 800 px
   * width; scales down on smaller viewports automatically because it's
   * a percentage of the parent). pointer-events:none so taps still
   * reach the underlying iframe. */
  /* Sits over the grey "RDM" text widget the firmware's default layout
   * renders in the centre gap — moved up from dead-centre so the red
   * brand mark fully covers the grey placeholder above the speed value. */
  #rdm-hero-{{ section.id }} .rh-dash-logo {
    position: absolute !important;
    top: 36% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    width: 17% !important;
    pointer-events: none !important;
    z-index: 2 !important;
  }
  #rdm-hero-{{ section.id }} .rh-dash-logo img {
    display: block !important;
    width: 100% !important;
    height: auto !important;
  }

  #rdm-hero-{{ section.id }} .rh-stats {
    position: relative !important; z-index: 1 !important;
    margin: 60px auto 0 !important;
    display: grid !important;
    grid-template-columns: repeat(4, 1fr) !important;
    gap: 24px !important;
  }
  @media (max-width: 720px) {
    #rdm-hero-{{ section.id }} .rh-stats { grid-template-columns: repeat(2, 1fr) !important; gap: 32px !important; }
  }
  #rdm-hero-{{ section.id }} .rh-stat-num {
    font-family: 'Space Grotesk', 'Inter', sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(40px, 5vw, 72px) !important;
    line-height: 1 !important;
    color: #CC0000 !important;
    letter-spacing: -0.025em !important;
    font-variant-numeric: tabular-nums !important;
  }
  #rdm-hero-{{ section.id }} .rh-stat-num span { font-size: 0.55em !important; font-weight: 700 !important; margin-left: 2px !important; }
  #rdm-hero-{{ section.id }} .rh-stat-label {
    margin-top: 10px !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 10px !important; font-weight: 500 !important;
    letter-spacing: 0.14em !important; text-transform: uppercase !important;
    color: rgba(255,255,255,0.4) !important;
  }
  #rdm-hero-{{ section.id }} .rh-status {
    position: relative !important; z-index: 1 !important;
    margin: 48px auto 0 !important;
    display: flex !important; justify-content: center !important;
  }
  #rdm-hero-{{ section.id }} .rh-status-inner {
    display: inline-flex !important; align-items: center !important; gap: 10px !important;
    font-family: 'JetBrains Mono', monospace !important;
    font-size: 10px !important; font-weight: 500 !important;
    letter-spacing: 0.18em !important;
    text-transform: uppercase !important;
    color: rgba(255,255,255,0.55) !important;
  }
  #rdm-hero-{{ section.id }} .rh-status-sep { color: rgba(255,255,255,0.18) !important; letter-spacing: 0 !important; }
  #rdm-hero-{{ section.id }} .rh-status-dot { color: #CC0000 !important; }
</style>

{%- comment -%}
  Build the demo URL once so the iframe markup stays clean. ?bare=1 is
  always on (hides the demo's own bezel since we have our own). ?gate=1
  is opt-in via section settings — flips the demo to a "Tap to start"
  state so the 2 MB WASM doesn't auto-download on every visit.
{%- endcomment -%}
{%- assign demo_base = section.settings.demo_url | default: 'https://trizzoto.github.io/rdm7-homepage-demo/' -%}
{%- assign demo_qs = '?bare=1' -%}
{%- if section.settings.gate_demo -%}
  {%- assign demo_qs = '?bare=1&gate=1' -%}
{%- endif -%}
{%- assign demo_url = demo_base | append: demo_qs -%}

<section id="rdm-hero-{{ section.id }}">
  <div class="rh-bg" aria-hidden="true">
    <div class="rh-bg-grid"></div>
    <div class="rh-bg-num">{{ section.settings.bg_number | default: '1200' }}</div>
  </div>

  <div class="rh-container rh-inner">
    <div class="rh-eyebrow">
      <span class="rh-eyebrow-dot">{{ section.settings.eyebrow_dot | default: '·' }}</span>
      <span>{{ section.settings.eyebrow_text }}</span>
    </div>
    <h1 class="rh-title">
      <span class="rh-title-white">{{ section.settings.title_line1 }}</span>
      <span class="rh-title-red">{{ section.settings.title_line2 }}</span>
    </h1>

    <div class="rh-bezel">
      <div class="rh-screen">
        <iframe
          class="rh-dash-iframe"
          src="{{ demo_url }}"
          loading="lazy"
          sandbox="allow-scripts allow-same-origin"
          title="RDM-7 Dash live demo"
          allow="autoplay"></iframe>

        {%- comment -%}
          RDM logo overlay — sits on top of the dash canvas in the centre
          gap of the default layout. Uses the same brand PNG shipped with
          the studio WASM, served from the demo repo's GitHub Pages
          deployment so there's no Shopify asset upload step.
        {%- endcomment -%}
        <div class="rh-dash-logo" aria-hidden="true">
          <img src="https://trizzoto.github.io/rdm7-homepage-demo/rdm-logo.png"
               alt=""
               loading="lazy"
               decoding="async">
        </div>
      </div>
    </div>

    <p class="rh-sub">{{ section.settings.subcopy }}</p>
    <div class="rh-cta">
      {% if section.settings.cta1_label != blank %}
        <a href="{{ section.settings.cta1_url | default: '#' }}" class="rh-btn">
          {{ section.settings.cta1_label }}
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true"><path d="M1 7H13M13 7L8 2M13 7L8 12" stroke="currentColor" stroke-width="1.8"/></svg>
        </a>
      {% endif %}
      {% if section.settings.cta2_label != blank %}
        <a href="{{ section.settings.cta2_url | default: '#' }}" class="rh-btn rh-btn--ghost">{{ section.settings.cta2_label }}</a>
      {% endif %}
    </div>
  </div>

  <div class="rh-container rh-stats">
    {% for block in section.blocks %}
      {% if block.type == 'stat' %}
        <div class="rh-stat" {{ block.shopify_attributes }}>
          <div class="rh-stat-num">{{ block.settings.number }}{% if block.settings.unit != blank %}<span>{{ block.settings.unit }}</span>{% endif %}</div>
          <div class="rh-stat-label">{{ block.settings.label }}</div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="rh-container rh-status">
    <div class="rh-status-inner">
      <span class="rh-status-sep">—</span>
      <span>{{ section.settings.status_left }}</span>
      <span class="rh-status-dot">·</span>
      <span>{{ section.settings.status_right }}</span>
      <span class="rh-status-sep">—</span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "RDM Home Hero",
  "tag": "section",
  "class": "section-rdm-home-hero",
  "settings": [
    { "type": "header", "content": "Eyebrow" },
    { "type": "text", "id": "eyebrow_dot",  "label": "Leading dot", "default": "·" },
    { "type": "text", "id": "eyebrow_text", "label": "Eyebrow text", "default": "INTRODUCING THE RDM-7" },
    { "type": "header", "content": "Title" },
    { "type": "text", "id": "title_line1", "label": "Line 1 (white)", "default": "Realtime Data." },
    { "type": "text", "id": "title_line2", "label": "Line 2 (red)",   "default": "ZERO Compromise." },
    { "type": "header", "content": "Subcopy" },
    { "type": "textarea", "id": "subcopy", "label": "Subcopy",
      "default": "7-inch touchscreen. <2 ms signal-to-screen latency. Full CAN compatibility. Build any layout you want in RDM Studio, push it to the dash, and drive." },
    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "cta1_label", "label": "Label", "default": "Shop RDM-7" },
    { "type": "url",  "id": "cta1_url",   "label": "Link" },
    { "type": "header", "content": "Secondary CTA" },
    { "type": "text", "id": "cta2_label", "label": "Label", "default": "Try RDM Studio" },
    { "type": "url",  "id": "cta2_url",   "label": "Link" },
    { "type": "header", "content": "Live demo" },
    {
      "type": "url",
      "id": "demo_url",
      "label": "Demo iframe URL",
      "info": "Defaults to the deployed WASM demo. Override if you ever move the demo to a custom subdomain."
    },
    {
      "type": "checkbox",
      "id": "gate_demo",
      "label": "Require tap to start (saves data on mobile)",
      "default": false,
      "info": "On: shows a Tap-to-start overlay; WASM downloads only after user clicks. Off: auto-loads ~2 MB on every visit."
    },
    { "type": "header", "content": "Background flourish" },
    { "type": "text", "id": "bg_number", "label": "Faint number behind hero", "default": "1200" },
    { "type": "header", "content": "Status strip" },
    { "type": "text", "id": "status_left",  "label": "Left text",  "default": "AUD $599" },
    { "type": "text", "id": "status_right", "label": "Right text", "default": "Shipping now" }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        { "type": "text", "id": "number", "label": "Number", "default": "100" },
        { "type": "text", "id": "unit",   "label": "Unit / suffix", "default": "%" },
        { "type": "text", "id": "label",  "label": "Label", "default": "Fully customisable" }
      ]
    }
  ],
  "presets": [
    {
      "name": "RDM Home Hero",
      "category": "Hero",
      "blocks": [
        { "type": "stat", "settings": { "number": "100", "unit": "%",  "label": "Fully customisable" } },
        { "type": "stat", "settings": { "number": "<2",  "unit": "ms", "label": "Signal-to-screen" } },
        { "type": "stat", "settings": { "number": "7",   "unit": "\"", "label": "Touch screen" } },
        { "type": "stat", "settings": { "number": "5",   "unit": "",   "label": "Saved layouts" } }
      ]
    }
  ]
}
{% endschema %}
